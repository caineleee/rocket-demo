# ========================================
# 全局环境配置模板 - 复制此文件为 .env 并修改对应值
# ========================================

# 宿主机 IP 地址（Docker 容器访问宿主机的地址）
# macOS/Linux: 通过 ifconfig 或 ip addr 查看
# Windows: 通过 ipconfig 查看
HOST_IP=192.168.5.48

# RocketMQ NameServer 地址（Docker 内部服务名，通常无需修改）
ROCKETMQ_NAMESRV_ADDR=namesrv-1:9876

# MySQL 数据库连接信息
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=rocket-demo-db
MYSQL_USERNAME=root
MYSQL_PASSWORD=root

# Nacos 注册中心地址（使用 ${HOST_IP} 引用宿主机 IP）
NACOS_SERVER_ADDR=${HOST_IP}:8848
