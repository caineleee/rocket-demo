        <id column="group_name" property="groupName" />
        <id column="msg_tag" property="msgTag" />
        <id column="msg_key" property="msgKey" />
        <result column="msg_id" property="msgId" />
        <result column="msg_body" property="msgBody" />
        <result column="consumer_status" property="consumerStatus" />
        <result column="consumer_times" property="consumerTimes" />
        <result column="consumer_time" property="consumerTime" />
        <result column="remark" property="remark" />
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        msg_id, group_name, msg_tag, msg_key, msg_body, consumer_status, consumer_times, consumer_time, remark
    </sql>

</mapper>
